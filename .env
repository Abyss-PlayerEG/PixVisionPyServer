# 应用配置
APP_NAME=像素视觉 Python 辅助服务 API
APP_VERSION=1.0.0
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000

# API 配置
API_V1_PREFIX=/api/v1
DOCS_URL=/docs
REDOC_URL=/redoc

# 请求超时配置
REQUEST_TIMEOUT=10

# B站 API 配置
BILIBILI_API_BASE=https://api.bilibili.com
# B站认证 Cookie（可选，但强烈建议配置以避免风控）
# 获取方法：登录 B站网页版 → F12 → Application → Cookies → 复制 SESSDATA 的值
BILIBILI_SESSDATA=
